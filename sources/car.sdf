<?xml version="1.0"?>
<sdf version="1.10">
  <model name="roadmap_car">
    <pose>0 0 0 0 0 0</pose>
    <static>false</static>
    <self_collide>false</self_collide>

    <link name="chassis">
      <pose>0 0 0.13 0 0 0</pose>
      <inertial>
        <mass>4.0</mass>
        <inertia>
          <ixx>0.03653</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.12653</iyy>
          <iyz>0</iyz>
          <izz>0.15000</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <box>
            <size>0.60 0.30 0.14</size>
          </box>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>1.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="body">
        <geometry>
          <box>
            <size>0.60 0.30 0.14</size>
          </box>
        </geometry>
        <material>
          <ambient>0.05 0.18 0.36 1</ambient>
          <diffuse>0.05 0.22 0.48 1</diffuse>
          <specular>0.25 0.25 0.25 1</specular>
        </material>
      </visual>
      <visual name="roof">
        <pose>-0.04 0 0.11 0 0 0</pose>
        <geometry>
          <box>
            <size>0.28 0.22 0.10</size>
          </box>
        </geometry>
        <material>
          <ambient>0.03 0.12 0.25 1</ambient>
          <diffuse>0.04 0.16 0.34 1</diffuse>
          <specular>0.25 0.25 0.25 1</specular>
        </material>
      </visual>
      <visual name="front_marker">
        <pose>0.29 0 0.02 0 0 0</pose>
        <geometry>
          <box>
            <size>0.02 0.18 0.04</size>
          </box>
        </geometry>
        <material>
          <ambient>0.95 0.18 0.08 1</ambient>
          <diffuse>1 0.22 0.10 1</diffuse>
        </material>
      </visual>
      <visual name="front_left_wheel_visual">
        <pose>0.18 0.125 -0.065 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.055</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
      <visual name="front_right_wheel_visual">
        <pose>0.18 -0.125 -0.065 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.055</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="left_wheel">
      <pose>-0.14 0.125 0.065 1.57079632679 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.000238</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000238</iyy>
          <iyz>0</iyz>
          <izz>0.000423</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.065</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>2.0</mu>
              <mu2>2.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.065</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="right_wheel">
      <pose>-0.14 -0.125 0.065 1.57079632679 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.000238</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000238</iyy>
          <iyz>0</iyz>
          <izz>0.000423</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.065</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>2.0</mu>
              <mu2>2.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.065</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_caster">
      <pose>0.20 0 0.04 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.000032</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000032</iyy>
          <iyz>0</iyz>
          <izz>0.000032</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.05</mu>
              <mu2>0.05</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.01</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.01</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="front_caster_joint" type="fixed">
      <parent>chassis</parent>
      <child>front_caster</child>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.25</wheel_separation>
      <wheel_radius>0.065</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_topic>/model/roadmap_car/odometry</odom_topic>
      <tf_topic>/model/roadmap_car/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>roadmap_car/chassis</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
    </plugin>
  </model>
</sdf>
